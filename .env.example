# Client/public. These values are intentionally available in the browser.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Server-only Supabase and scheduled jobs. Required in production.
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Server-only Web Push. Required when push is enabled in production.
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:drift@example.invalid

# Server-only legacy OnlinePOS API.
ONLINEPOS_BASE_URL=
ONLINEPOS_TOKEN=
ONLINEPOS_FIRMAID=

# Server-only OnlinePOS Reports/OAuth API.
ONLINEPOS_REPORTS_BASE_URL=
ONLINEPOS_REPORTS_TOKEN=
ONLINEPOS_CLIENT_ID=
ONLINEPOS_CLIENT_SECRET=
ONLINEPOS_VENUE_ID=
ONLINEPOS_CONCERN=

# Optional, owner-protected test tools. Keep false in production unless actively used.
BACKEVENT_ENABLE_ONLINEPOS_REPLAY=false
BACKEVENT_ENABLE_RETURN_TEST_HARNESS=false
